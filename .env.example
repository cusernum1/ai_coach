# ============================================================
# .env.example — шаблон окружения для дипломной работы
# ============================================================
# Скопируйте в .env:  cp .env.example .env
# и заполните значения. Файл .env в git не коммитится.
# ============================================================

# ── LLM ──────────────────────────────────────────────────────
# groq | openrouter
LLM_PROVIDER=groq

# Groq:       https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

MAX_TOKENS=2048
TEMPERATURE=0.7

# ── Telegram-бот ─────────────────────────────────────────────
# @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# @userinfobot → ваш Telegram ID (станет первым тренером-админом)
ADMIN_TELEGRAM_ID=
BOT_NAME=AI Coach

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_coach
# 1 = использовать SQLite (coach.db) вместо Postgres (удобно для dev/демо)
SQLITE_FALLBACK=0

# ── Планировщик ──────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/Moscow
DAILY_POLL_TIME=08:00

# ── Strava OAuth ─────────────────────────────────────────────
# https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/strava/callback

# ── Telegram Payments ────────────────────────────────────────
# @BotFather → /mybots → Payments → выбрать провайдера
PAYMENTS_PROVIDER_TOKEN=
PAYMENTS_CURRENCY=RUB

# ── Web Mini-App ─────────────────────────────────────────────
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
WEBAPP_PUBLIC_URL=http://localhost:8080

# ── Логи ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
